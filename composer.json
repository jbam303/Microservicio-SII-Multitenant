{
    "name": "manhattan-pos/libredte-service",
    "description": "Microservicio wrapper de LibreDTE para Manhattan POS",
    "type": "project",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "libredte/libredte-lib-core": "^24.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "ignore",
            "block-insecure": false
        }
    }
}